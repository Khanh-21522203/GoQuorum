    {
      "type": "text",
      "id": "artifact_ae_text",
      "x": 760, "y": 655,
      "width": 270, "height": 76,
      "text": "// Merkle bucket mapping\nfunc (mt *MerkleTree) keyToBucket(\n    key []byte) int {\n  h := sha256.Sum256(key)\n  idx := binary.BigEndian.Uint64(h[:8])\n  return int(idx % uint64(mt.numBuckets))\n}",
      "originalText": "// Merkle bucket mapping\nfunc (mt *MerkleTree) keyToBucket(\n    key []byte) int {\n  h := sha256.Sum256(key)\n  idx := binary.BigEndian.Uint64(h[:8])\n  return int(idx % uint64(mt.numBuckets))\n}",
