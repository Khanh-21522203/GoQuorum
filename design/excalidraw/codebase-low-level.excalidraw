    {
      "type": "text",
      "id": "w1_text",
      "x": 35, "y": 133,
      "width": 270, "height": 70,
      "text": "1. CLIENT REQUEST\nPUT /v1/{key}  →  grpc-gateway\n→ pb.GoQuorumServer.Put()\n→ ClientAPI.Put(key, value, context)",
      "originalText": "1. CLIENT REQUEST\nPUT /v1/{key}  →  grpc-gateway\n→ pb.GoQuorumServer.Put()\n→ ClientAPI.Put(key, value, context)",
