    {
      "type": "text",
      "id": "artifact_read_text",
      "x": 400, "y": 770,
      "width": 260, "height": 94,
      "text": "// VClock comparison for merge\nfunc (vc VectorClock) HappensBefore(\n    other VectorClock) bool {\n  dominated := false\n  for node, ts := range vc {\n    if ts > other[node] { return false }\n    if ts < other[node] { dominated = true }\n  }\n  return dominated\n}",
      "originalText": "// VClock comparison for merge\nfunc (vc VectorClock) HappensBefore(\n    other VectorClock) bool {\n  dominated := false\n  for node, ts := range vc {\n    if ts > other[node] { return false }\n    if ts < other[node] { dominated = true }\n  }\n  return dominated\n}",
      "fontSize": 10,
      "fontFamily": 3,
