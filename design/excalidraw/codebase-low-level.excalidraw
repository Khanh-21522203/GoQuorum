    {
      "type": "text",
      "id": "w2_text",
      "x": 35, "y": 231,
      "width": 270, "height": 80,
      "text": "2. COORDINATOR.PUT\nValidate key + value constraints\nvclock.Tick(nodeID) → new VClock version\nBuild SiblingSet{Value, VClock, Timestamp, ExpiresAt}",
      "originalText": "2. COORDINATOR.PUT\nValidate key + value constraints\nvclock.Tick(nodeID) → new VClock version\nBuild SiblingSet{Value, VClock, Timestamp, ExpiresAt}",
