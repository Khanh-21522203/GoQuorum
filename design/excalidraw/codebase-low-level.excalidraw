    {
      "type": "text",
      "id": "artifact_write_text",
      "x": 40, "y": 770,
      "width": 260, "height": 94,
      "text": "// parallelWrite goroutines\nfor _, nodeID := range prefList {\n  go func(nid NodeID) {\n    if nid == c.nodeID {\n      err = c.localWrite(key, siblings)\n    } else {\n      err = c.rpc.RemotePut(ctx, nid, key, siblings)\n    }\n  }(nodeID)\n}",
      "originalText": "// parallelWrite goroutines\nfor _, nodeID := range prefList {\n  go func(nid NodeID) {\n    if nid == c.nodeID {\n      err = c.localWrite(key, siblings)\n    } else {\n      err = c.rpc.RemotePut(ctx, nid, key, siblings)\n    }\n  }(nodeID)\n}",
      "fontSize": 10,
