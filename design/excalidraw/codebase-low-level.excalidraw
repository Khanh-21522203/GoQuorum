    {
      "type": "text",
      "id": "w3_text",
      "x": 35, "y": 339,
      "width": 270, "height": 70,
      "text": "3. CONSISTENT HASH ROUTING\nring.GetPreferenceList(key, N=3)\nxxhash(key) → virtual node → physical node\nReturns N ordered replica node IDs",
      "originalText": "3. CONSISTENT HASH ROUTING\nring.GetPreferenceList(key, N=3)\nxxhash(key) → virtual node → physical node\nReturns N ordered replica node IDs",
      "fontSize": 11,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "middle",
      "strokeColor": "#374151",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
